# Monolith OS Kernel Configuration — ARM64 Server
# Optimized for ARM64 server platforms: Graviton, Ampere Altra, Apple Silicon

# General
CONFIG_LOCALVERSION="-monolith"
CONFIG_DEFAULT_HOSTNAME="monolith"

# Processor — ARM64
CONFIG_ARM64=y
CONFIG_ARM64_SVE=y
CONFIG_ARM64_LSE_ATOMICS=y
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_BTI=y
CONFIG_ARCH_SUPPORTS_HUGE_VMAP=y
CONFIG_SMP=y
CONFIG_NR_CPUS=256

# NUMA
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y

# Transparent Huge Pages
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y

# Scheduler — BORE patch
CONFIG_SCHED_BORE=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_NO_HZ_FULL=y

# Networking — same as x86_64
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_DEFAULT_NET_SCH="fq"
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_NF_CONNTRACK=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y
CONFIG_WIREGUARD=y
CONFIG_MPTCP=y
CONFIG_XDP_SOCKETS=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# Storage & I/O
CONFIG_BLK_DEV_NVME=y
CONFIG_SATA_AHCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_DM_CRYPT=y
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_BTRFS_FS=y
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_IO_URING=y
CONFIG_MQ_IOSCHED_KYBER=y

# Virtualization
CONFIG_KVM=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VHOST_NET=y

# Security
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_INTEGRITY=y
CONFIG_IMA=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Containers
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_V2=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_NET_CLS_CGROUP=y
CONFIG_OVERLAY_FS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y

# Disabled — not needed on servers
CONFIG_SOUND=n
CONFIG_BT=n
CONFIG_WIRELESS=n
CONFIG_USB_HID=n
CONFIG_DRM=n
CONFIG_PCMCIA=n
CONFIG_FIREWIRE=n
CONFIG_INPUT_TOUCHSCREEN=n
CONFIG_INPUT_JOYSTICK=n
CONFIG_MEDIA_SUPPORT=n
