# Monolith OS — MariaDB tuning overrides
# Place under /etc/mysql/conf.d/ inside the container.

[mysqld]
# Networking
bind-address = 0.0.0.0
max_allowed_packet = 64M

# Query cache (disabled by default in 10.1.7+ — keep off for write-heavy)
query_cache_type = 0
query_cache_size = 0

# Slow query logging
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1

# General log (off by default; toggle for debugging)
general_log = 0

# Performance schema
performance_schema = ON

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
